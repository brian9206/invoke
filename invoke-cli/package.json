{
  "name": "invoke-cli",
  "version": "2.0.3",
  "description": "CLI tool for managing Invoke functions, admin accounts, and API keys",
  "bin": {
    "invoke": "dist/invoke"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "npm run typecheck && bun scripts/build.ts",
    "build:postinstall": "npm run typecheck && bun build ./scripts/postinstall.ts --outdir ./dist --minify --target node --format cjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:postinstall && bun scripts/prepublishOnly.ts",
    "postpublish": "bun scripts/postpublish.ts",
    "postinstall": "node postinstall.js"
  },
  "files": [
    "postinstall.js",
    "dist/postinstall.js",
    "dist/invoke"
  ],
  "dependencies": {},
  "devDependencies": {},
  "keywords": [
    "invoke",
    "cli",
    "admin",
    "management",
    "serverless",
    "functions"
  ],
  "author": "Brian Choi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brian9206/invoke.git"
  },
  "homepage": "https://brianchoi.me/invoke/docs/cli/installation",
  "bugs": {
    "url": "https://github.com/brian9206/invoke/issues"
  }
}