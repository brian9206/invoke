{
  "name": "invoke-cli",
  "version": "2.0.0",
  "description": "CLI tool for managing Invoke functions, admin accounts, and API keys",
  "bin": {
    "invoke": "./dist/invoke"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "npm run typecheck && bun scripts/build.ts",
    "build:postinstall": "npm run typecheck && bun build ./scripts/postinstall.ts --outdir ./dist --minify --target node --format cjs",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build:postinstall",
    "postinstall": "node postinstall.js"
  },
  "files": [
    "postinstall.js",
    "dist/postinstall.js"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^20",
    "@types/zxcvbn": "^4.4.4",
    "adm-zip": "^0.5.10",
    "archiver": "^6.0.1",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.0",
    "ignore": "^5.3.2",
    "inquirer": "^12.11.1",
    "invoke-shared": "*",
    "invoke-worker": "*",
    "pg": "^8.11.3",
    "table": "^6.8.1",
    "zxcvbn": "^4.4.2",
    "listr2": "^10.2.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "invoke",
    "cli",
    "admin",
    "management",
    "serverless",
    "functions"
  ],
  "author": "Brian Choi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brian9206/invoke"
  },
  "homepage": "https://brianchoi.me/invoke/docs/cli/installation",
  "bugs": {
    "url": "https://github.com/brian9206/invoke/issues"
  }
}
