# Invoke Logger Service Environment Configuration

# Service Configuration
PORT=3004

# App Database (invoke_db — used to resolve function/project names and for cleanup logic)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=invoke_db
DB_USER=postgres
DB_PASSWORD=invoke_password_123

# Log Database (invoke_logs — dedicated DB for storing function logs)
# Defaults to DB_* values above if not set
LOG_DB_HOST=localhost
LOG_DB_PORT=5432
LOG_DB_NAME=invoke_logs
LOG_DB_USER=postgres
LOG_DB_PASSWORD=invoke_password_123

# Internal secret — must match INTERNAL_SERVICE_SECRET in all other services
INTERNAL_SERVICE_SECRET=your_INTERNAL_SERVICE_SECRET_change_in_production
