# Invoke Execution Service Environment Configuration

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=invoke_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# S3-compatible Object Storage Configuration (MinIO by default)
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=invoke-packages

# Service Configuration
PORT=3001
TRUST_PROXY=true

# Cache Configuration
MAX_CACHE_SIZE_GB=10
CACHE_CLEANUP_INTERVAL_MS=3600000

# Rate Limiting (requests per 15 minutes per IP address)
RATE_LIMIT=100

# Internal Gateway Verification
# Shared secret used to verify signed JWTs injected by invoke-gateway.
# Must match INTERNAL_SERVICE_SECRET in the gateway service.
# If unset, gateway token verification is disabled (fallback to req.ip).
INTERNAL_SERVICE_SECRET=your_INTERNAL_SERVICE_SECRET_change_in_production

# Sandbox Orchestrator Configuration
SANDBOX_RUNTIME=runsc
SANDBOX_MIN_POOL_SIZE=5
SANDBOX_MAX_POOL_SIZE=20
SANDBOX_MEMORY_MB=1024
GVISOR_PLATFORM=kvm

# Response logging controls
MAX_RESPONSE_LOG_SIZE=10240

# Service URLs
GATEWAY_SERVICE_URL=http://localhost:3002
LOGGER_SERVICE_URL=http://localhost:3004