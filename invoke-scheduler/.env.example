# Endpoint configuration
EXECUTION_SERVICE_URL=http://localhost:3001
ADMIN_SERVICE_URL=http://localhost:3000
LOGGER_SERVICE_URL=http://localhost:3004

# Internal secret shared with the admin service for service-to-service calls
INTERNAL_SERVICE_SECRET=your_internal_service_secret_change_in_production

# Intervals
SCHEDULER_INTERVAL=60000        # How often (ms) to check for scheduled tasks
LOG_CLEANUP_INTERVAL=3600000    # How often (ms) to clean up old logs (e.g., every hour)


