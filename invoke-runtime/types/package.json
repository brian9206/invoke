{
  "name": "invoke-types",
  "version": "1.0.1",
  "description": "Type definitions for Invoke Runtime",
  "license": "MIT",
  "types": "dist/ambient.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ambient.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/ambient.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brian9206/invoke.git",
    "directory": "invoke-runtime/types"
  },
  "bugs": {
    "url": "https://github.com/brian9206/invoke/issues"
  },
  "homepage": "https://github.com/brian9206/invoke#readme",
  "scripts": {
    "build": "tsc && node scripts/build.js --target=ambient --output=dist/ambient.d.ts dist/tsc/",
    "build:editor": "tsc && node scripts/build.js --target=editor --output=dist/editor.d.ts dist/tsc/",
    "test": "tsc test.ts --noEmit --skipLibCheck",
    "prepack": "node run build && node run test"
  },
  "dependencies": {
    "@types/bun": "^1.3.12"
  },
  "devDependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
