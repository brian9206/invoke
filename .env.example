# MinIO Object Storage / S3-compatible Configuration
# MINIO_ROOT_USER and MINIO_ROOT_PASSWORD configure the MinIO server container.
# S3_* vars are used by application services.
MINIO_ROOT_USER=invoke-minio
MINIO_ROOT_PASSWORD=invoke-minio-password-123
S3_ACCESS_KEY=invoke-minio
S3_SECRET_KEY=invoke-minio-password-123
S3_BUCKET=invoke-packages

# Application Secrets
JWT_SECRET=your_jwt_secret_change_in_production
INTERNAL_SERVICE_SECRET=your_internal_service_secret_change_in_production

# App Database Connection
DB_NAME=invoke_db
DB_USER=postgres
DB_PASSWORD=invoke_password_123

# Logger Database Connection
LOG_DB_NAME=invoke_logs
LOG_DB_USER=postgres
LOG_DB_PASSWORD=invoke_password_123

# Service Ports
ADMIN_PORT=3000
EXECUTION_PORT=3001
GATEWAY_PORT=3002

# Execution Service Configuration
RATE_LIMIT=100
EXECUTION_TIMEOUT=30000
CACHE_TTL_DAYS=7
MAX_CACHE_SIZE_GB=10
TRUST_PROXY=1

# Scheduler Configuration
SCHEDULER_INTERVAL=60000        # How often (ms) to check for scheduled tasks
LOG_CLEANUP_INTERVAL=3600000    # How often (ms) to clean up old logs (e.g., every hour)
TZ=Asia/Hong_Kong

# Gateway Service Route Cache
# How often (ms) to refresh the route cache from the database
CACHE_REFRESH_INTERVAL=60000

# Cloudflare Turnstile (CAPTCHA)
# Get your keys from https://dash.cloudflare.com/
# For testing, use: 1x00000000000000000000AA (always passes)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Replicas
# For real world usage, recommend to have multiple gateway and execution service replicas behind a load balancer.
EXECUTION_REPLICAS=1
GATEWAY_REPLICAS=1
LOGGER_REPLICAS=1
